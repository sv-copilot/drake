{
  "schema_version": 1,
  "profile_id": "example-project",
  "description": "Example MCP environment profile for a product repo.",
  "default_tier": "dev",
  "credential_policy": {
    "forbidden_in_tiers": ["dev"],
    "human_gate_tiers": ["production"]
  },
  "tiers": {
    "dev": {
      "description": "Local development with localhost services and no production credentials.",
      "mcp_servers": {
        "database": {
          "enabled": true,
          "transport": "stdio",
          "command": "npx",
          "args": ["-y", "example-mcp-server-postgres", "postgresql://localhost:5432/dev"],
          "credential_refs": []
        }
      }
    },
    "staging": {
      "description": "Staging workers connect to shared staging infrastructure.",
      "mcp_servers": {
        "search": {
          "enabled": true,
          "transport": "sse",
          "url": "https://staging-search.example.com/mcp",
          "credential_refs": ["SEARCH_MCP_API_KEY"]
        }
      }
    },
    "production": {
      "description": "Production MCP servers require operator approval per environment gate.",
      "mcp_servers": {
        "deploy": {
          "enabled": false,
          "transport": "streamable_http",
          "url": "https://deploy.example.com/mcp/v1",
          "credential_refs": ["DEPLOY_MCP_TOKEN"],
          "notes": "Enable only during approved release windows."
        }
      }
    }
  }
}
