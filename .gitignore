# Local env files (committed examples use .env.example only)
.env
.env.*
!.env.example
!.env.*.example

# Local operator notes with real secret values or paths
SECRETS.local.md
*.local.md

# OS / editor
.DS_Store
.idea/
.vscode/

# Future shared tool build artifacts (when populated)
shared/**/node_modules/
shared/**/.venv/
shared/**/__pycache__/
shared/**/dist/
shared/**/build/

# Portfolio-local tool build artifacts
tools/**/node_modules/
tools/**/dist/
scripts/**/__pycache__/

# Hosted service local Python artifacts
services/**/.venv/
services/**/.pytest_cache/
services/**/__pycache__/
services/**/*.egg-info/

# Hosted web local artifacts
apps/**/node_modules/
apps/**/.next/
apps/**/coverage/
apps/**/test-results/
apps/**/playwright-report/
apps/**/*.tsbuildinfo

# Keep future project symlinks/repos out of portfolio git
projects/*
!projects/README.md
__pycache__/
